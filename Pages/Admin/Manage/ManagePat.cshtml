@page "{patId}"
@model CloudClinic.Admin.Pages.Manage.ManagePat

<section class="content">
    <div class="body_scroll">
        <div class="block-header">
            <div class="row">
                <div class="col-lg-7 col-md-6 col-sm-12">
                    <h2>Pat Detail</h2>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="index.html"><i class="zmdi zmdi-home"></i> Home</a></li>
                        <li class="breadcrumb-item active">Patient Detail</li>
                    </ul>
                    <button class="btn btn-primary btn-icon mobile_menu" type="button"><i class="zmdi zmdi-sort-amount-desc"></i></button>
                </div>
                <div class="col-lg-5 col-md-6 col-sm-12">
                    <button class="btn btn-primary btn-icon float-right right_icon_toggle_btn" type="button"><i class="zmdi zmdi-arrow-right"></i></button>
                </div>
            </div>
        </div>
        <div class="container-fluid">
            <div class="row clearfix">
                <div class="col-lg-12">
                    <div class="card">
                        <div class="body">
                            <div class="row">
                                <div class="col-xl-3 col-lg-4 col-md-12">
                                    <div class="preview preview-pic tab-content">
                                        <div class="tab-pane active">
                                            <img src="@Model.Pat.ProfilePicUri" class="img-fluid" alt="" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-xl-9 col-lg-8 col-md-12">
                                    <div class="product details">
                                        <h3 class="product-title mb-0">@Model.Pat.FullName</h3>
                                        <hr>
                                        <p class="product-description">
                                            He is from @Model.Pat.Address and joined on <b>@Model.Pat.RegDate</b>
                                        </p>

                                        @if (Model.Pat.IsRemoved)
                                        {
                                            <p class="alert-info" style="padding: 10px; border-left: 4px red solid;">
                                               <strong>Removal Cause: </strong> @Model.Pat.RemovalCause

                                            </p>

                                            <div class="action">
                                                <a asp-page-handler="UnRemovePat"
                                                   asp-route-drId="@Model.Pat.PatId"
                                                   class="btn btn-primary waves-effect">
                                                    Un-Remove
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                @if (Model.Pat.IsRemoved == false)
                {
                    <div class="col-lg-12">
                        <p>Remove Pat.</p>
                        <form asp-page-handler="RemovePat" method="post" id="pat-removel-form">
                            <small>Removal Reason</small>
                            <input type="hidden" asp-for="PatId" value="@Model.Pat.PatId" />
                            <textarea class="form-control" asp-for="Cause"></textarea>
                            <input type="submit"
                                   onclick="submitForm('pat-removel-form')" />
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
