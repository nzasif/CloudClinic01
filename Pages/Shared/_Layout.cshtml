<!doctype html>
<html class="no-js " lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=Edge">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <meta name="description" content="Cloud Clinic">
    <title>:: Admin :: Home</title>
    <link rel="icon" href="favicon.ico" type="image/x-icon"> <!-- Favicon-->
    <link rel="stylesheet" href="~/admin/plugins/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/admin/plugins/jvectormap/jquery-jvectormap-2.0.3.min.css" />
    <link rel="stylesheet" href="~/admin/plugins/charts-c3/plugin.css" />

    <link rel="stylesheet" href="~/admin/plugins/morrisjs/morris.min.css" />
    <!-- Custom Css -->
    <link rel="stylesheet" href="~/admin/css/style.min.css">
</head>

<body class="theme-blush">

    <!-- Page Loader -->
    <div class="page-loader-wrapper">
        <div class="loader">
            <div class="m-t-30"><img class="zmdi-hc-spin" src="~/admin/images/loader.svg" width="48" height="48" alt="Cloud Clinic"></div>
            <p>Please wait...</p>
        </div>
    </div>

    <!-- Overlay For Sidebars -->
    <div class="overlay"></div>

    <!-- Right Icon menu Sidebar -->
    <div class="navbar-right">
        <ul class="navbar-nav">
            <li>
                <a asp-page="/Admin/Account/AdminLogin" asp-page-handler="logout" class="mega-menu" title="Sign Out">
                    <i class="zmdi zmdi-power"></i>
                </a>
            </li>
        </ul>
    </div>
    <!-- Left Sidebar -->
    <aside id="leftsidebar" class="sidebar">
        <div class="navbar-brand">
            <button class="btn-menu ls-toggle-btn" type="button"><i class="zmdi zmdi-menu"></i></button>
            <a asp-page="/"><img src="~/admin/images/logo.svg" width="25" alt="cloud clinic"><span class="m-l-10">Cloud Clinic</span></a>
        </div>
        <div class="menu">
            <ul class="list">
                <li>
                    <div class="user-info">
                        <span class="image"><img src="~/admin/images/profile_av.png" alt="User"></span>
                        <div class="detail">
                            <h4>Cloud Clinic</h4>
                            <small>Admin</small>
                        </div>
                    </div>
                </li>
                <li class="active open"><a href="index.html"><i class="zmdi zmdi-home"></i><span>Dashboard</span></a></li>
                <li>
                    <a href="javascript:void(0);" class="menu-toggle"><i class="zmdi zmdi-apps"></i><span>Registerd Drs</span></a>
                    <ul class="ml-menu">
                        <li><a class="link" asp-area="" asp-page="/Admin/Manage/ViewDrs">All Drs</a></li>
                    </ul>
                </li>
                <li>
                    <a href="javascript:void(0);" class="menu-toggle"><i class="zmdi zmdi-assignment"></i><span>Registerd Patients</span></a>
                    <ul class="ml-menu">
                        <li><a asp-page="/Admin/Manage/ViewPats">Patients List</a></li>
                    </ul>
                </li>
                <li>
                    <a href="javascript:void(0);" class="menu-toggle">
                        <span>Reported Pat. Reviews</span>
                    </a>
                    <ul class="ml-menu">
                        <li><a asp-page="/Admin/Manage/ViewReportedReviews">Pat. Reviews</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </aside>

    <!-- Main Content -->
    @RenderBody()

    <!-- Jquery Core Js -->
    <script src="~/admin/bundles/libscripts.bundle.js"></script> <!-- Lib Scripts Plugin Js ( jquery.v3.2.1, Bootstrap4 js) -->
    <script src="~/admin/bundles/vendorscripts.bundle.js"></script> <!-- slimscroll, waves Scripts Plugin Js -->

    <script src="~/admin/bundles/jvectormap.bundle.js"></script> <!-- JVectorMap Plugin Js -->
    <script src="~/admin/bundles/sparkline.bundle.js"></script> <!-- Sparkline Plugin Js -->
    <script src="~/admin/bundles/c3.bundle.js"></script>

    <script src="~/admin/bundles/mainscripts.bundle.js"></script>
    <script src="~/admin/js/pages/index.js"></script>


    @*<script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>*@
    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
